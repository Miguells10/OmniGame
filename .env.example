# ─────────────────────────────────────────────────────────────────
# OmniGame AI — Environment Variables Example
# Copy this file to '.env' before running docker-compose up
# ─────────────────────────────────────────────────────────────────

# Supabase JWT Secret (Required for authenticating requests)
# In production, get this from your Supabase Dashboard: Settings > API > JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here

# OpenAI API Key (Required for The Collector RAG Assistant)
OPENAI_API_KEY=sk-your-openai-key-here

# Database Settings (Leave as default for local docker-compose pgvector)
SUPABASE_DB_NAME=omnigame
SUPABASE_DB_PASSWORD=postgrespassword
